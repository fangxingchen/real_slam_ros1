<launch>
  <!-- 【实车模式】PID 局部规划器启动文件 -->
  <rosparam file="$(find robot_pid_local_planner)/config/omnidirectional_pid_param.yaml" command="load"/>

  <!-- 实车模式：IS_SIM=false，从 /carto_odom 获取位置和速度 -->
  <param name="IS_SIM" value="false" />

  <node pkg="robot_pid_local_planner"
        type="omnidirectional_pid_local_planner_node"
        name="omnidirectional_pid_local_planner"
        output="screen">
  </node>
</launch>
